# ============================================
# OnBoardIQ - Git Ignore
# ============================================


# --------------------------------------------
# Python
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/


# --------------------------------------------
# Python Virtual Environments
# --------------------------------------------
.venv/
venv/
env/
ENV/


# --------------------------------------------
# Environment Variables / Secrets
# --------------------------------------------
.env
.env.*
!.env.example

*.pem
*.key
*.crt

secrets/
credentials/


# --------------------------------------------
# Node / React / Vite
# --------------------------------------------
node_modules/
frontend/node_modules/

frontend/dist/
frontend/build/

dist/
build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.npm/
.yarn/
.pnpm-store/


# --------------------------------------------
# Vite
# --------------------------------------------
.vite/
frontend/.vite/

*.local


# --------------------------------------------
# Generated Data / Analytics Cache
# --------------------------------------------
*.parquet
*.feather

synthetic_data/output/
synthetic_data/generated/
generated_data/

data/cache/
cache/

*.cache


# --------------------------------------------
# Large Data Files
# --------------------------------------------
*.csv
*.xlsx
*.xls

# Keep sample/demo datasets if required
!**/sample*.csv
!**/demo*.csv


# --------------------------------------------
# Machine Learning Artifacts
# --------------------------------------------
*.pkl
*.pickle
*.joblib

models/
checkpoints/


# --------------------------------------------
# Database
# --------------------------------------------
*.db
*.sqlite
*.sqlite3

mysql_data/

# MySQL dumps containing local data
*.sql.gz
*.dump

# Keep database schema files
!database/schema.sql


# --------------------------------------------
# Logs
# --------------------------------------------
*.log
logs/

backend/logs/


# --------------------------------------------
# Test Artifacts
# --------------------------------------------
.pytest_cache/
test-results/
coverage/

tests/__pycache__/


# --------------------------------------------
# IDE / Editors
# --------------------------------------------
.vscode/
.idea/

*.swp
*.swo
*~

.project
.classpath
.settings/


# --------------------------------------------
# Jupyter Notebook
# --------------------------------------------
.ipynb_checkpoints/


# --------------------------------------------
# Operating System
# --------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

Thumbs.db
Thumbs.db:encryptable
Desktop.ini


# --------------------------------------------
# Temporary Files
# --------------------------------------------
tmp/
temp/

*.tmp
*.temp
*.bak


# --------------------------------------------
# Exported Dashboard Files
# --------------------------------------------
exports/
downloads/

*.png
*.pdf

# Keep frontend assets
!frontend/public/**/*.png
!frontend/src/assets/**/*.png


# --------------------------------------------
# Docker
# --------------------------------------------
docker-data/
.docker/


# --------------------------------------------
# Local Development
# --------------------------------------------
.local/
local/

dev-data/